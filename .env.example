# Copy this to .env and fill in real values
OLHOVIVO_TOKEN=your_sptrans_token_here
JWT_SECRET=change_me_to_random_32_char_string_here

# AbacatePay (payments) - leave empty to use mock mode
AbacatePay:ApiKey=
AbacatePay:BaseUrl=https://api.abacatepay.com
AbacatePay:CallbackUrl=https://trilho.app

# Firebase Cloud Messaging
Firebase:CredentialsPath=/path/to/firebase-credentials.json
